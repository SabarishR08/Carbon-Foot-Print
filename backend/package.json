{
  "name": "carbon-footprint-api",
  "version": "1.0.0",
  "description": "Carbon Footprint Platform - Cloud Run API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage --forceExit",
    "test:integration": "jest --testPathPattern=integration --forceExit",
    "lint": "eslint src/",
    "docker:build": "docker build -t carbon-footprint-api .",
    "docker:run": "docker run -p 8080:8080 -e GCP_PROJECT_ID=agentflow-prod-assistant carbon-footprint-api",
    "docker:build:local": "docker build -t carbon-footprint-api-local .",
    "docker:run:local": "docker run --rm -p 8080:8080 --env-file .env carbon-footprint-api-local"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.3.0",
    "@google-cloud/firestore": "^7.3.1",
    "@google-cloud/pubsub": "^4.3.3",
    "@google-cloud/secret-manager": "^5.0.1",
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/tasks": "^5.1.0",
    "@google-cloud/vertexai": "^1.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.1.0",
    "joi": "^17.12.0",
    "morgan": "^1.10.0",
    "pdfkit": "^0.15.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
